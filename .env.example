# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env

# === Обязательное ===
# Токен бота от @BotFather (https://t.me/BotFather -> /newbot)
BOT_TOKEN=123456:put-your-token-here

# === Уведомления ===
TZ=Europe/Moscow
QOTD_HOUR=9
QOTD_MINUTE=0
# Час ежедневного напоминания о карточках к повторению (due)
REMINDER_HOUR=20
# Сколько новых карточек вводить в день (дозированный spaced repetition)
DAILY_NEW_LIMIT=15

# === LLM-проверка ответов (Google Gemini, опционально) ===
# Ключ из Google AI Studio (https://aistudio.google.com/apikey). Пусто -> режим выкл.
GEMINI_API_KEY=
# Цепочка моделей через запятую: лимит/ошибка на одной -> запрос на следующую
GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-flash

# === Хранилище ===
# Локально можно оставить пустым -> используется файл DB_PATH (data/bot.db).
# На хостинге с эфемерной ФС (Render free) задай Turso, чтобы прогресс не терялся:
#   создай БД на https://turso.tech и подставь url + токен.
DB_PATH=data/bot.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# === Webhook (для хостинга) ===
# Если задать WEBHOOK_URL — бот переключается с polling на webhook+HTTP-сервер.
# WEBHOOK_URL = публичный https-адрес сервиса (без слеша на конце),
# например https://mlsobesbot.onrender.com
WEBHOOK_URL=
PORT=10000
# Keep-alive: пинговать себя каждые N минут, чтобы free-сервис не уснул (<15).
KEEPALIVE_MINUTES=10
